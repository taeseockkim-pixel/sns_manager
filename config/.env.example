# X (Twitter) API v2 - Basic Tier 필요 ($100/월)
# 신청: https://developer.twitter.com/en/portal/products/basic
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=

# Meta (Facebook/Instagram)
# 신청: https://developers.facebook.com/
# 필요 권한: pages_manage_posts, pages_read_engagement
META_APP_ID=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=
META_PAGE_ID=
META_IG_USER_ID=

# Threads
# 발급: Meta 개발자 포털 → 앱 설정 → Threads 앱
# OAuth: 서버 실행 후 /setup 페이지에서 "Threads OAuth 연결" 클릭
# 필요 권한: threads_basic, threads_content_publish, threads_read_replies
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# LinkedIn (Phase 2)
# 신청: https://www.linkedin.com/developers/
# 필요 권한: w_member_social, r_organization_social
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_COMPANY_ID=

# Anthropic API
# 발급: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# 알림 설정
SLACK_WEBHOOK_URL=
ALERT_EMAIL=taeseock.kim@cimon.com

# DB 경로
DB_PATH=./sns_management.db

# CIMON SNS 계정 (모니터링 대상 — 실제 계정 정보로 교체)
CIMON_X_HANDLE=@cimon_official
CIMON_FB_PAGE_ID=
CIMON_IG_USER_ID=

# 웹 대시보드 인증 (팀 서버 배포 시 변경 필수)
DASHBOARD_USERNAME=cimon
DASHBOARD_PASSWORD=cimon2024

# 서버 설정
HOST=0.0.0.0
PORT=8000

# SSL 설정 (회사 프록시/SSL 인터셉션 환경)
# 방법 1 (권장): 회사 CA 인증서 .pem 경로 지정
# REQUESTS_CA_BUNDLE=C:/certs/company-ca.pem
# 방법 2 (개발 임시): SSL 검증 완전 비활성화
# SSL_VERIFY_DISABLED=true

# API 모드: live (실제 API 호출) — mock 모드는 사용 금지
API_MODE=live

# DB 초기화: mock 이벤트 포함 monitoring_events 전체 삭제 후 재수집
# 사용법: Vercel 환경변수에 추가 → 1회 배포 → 즉시 제거
# WIPE_MOCK_ON_START=true
